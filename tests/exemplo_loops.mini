// Exemplo com loops e condicionais

var limit: int = 10;

def main(): int {
    var i: int = 0;
    var soma: int = 0;
    
    while (i < limit) {
        set soma = soma + i;
        set i = i + 1;
        
        if (i == 5) {
            print "Meio do caminho";
        }
    }
    
    print "Loop completo";
    return 0;
}
